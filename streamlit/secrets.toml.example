# Copy to .streamlit/secrets.toml and add your project URL + anon key.
# Create Supabase tables `pps_sessions` and `pps_contacts` with columns matching
# `pps_research._supabase_pps_insert` and `_supabase_pps_contact_insert`, or add
# compatible JSON/JSONB columns and adjust the payload in `pps_research.py`.

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
key = "YOUR_ANON_KEY"
